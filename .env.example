# 开发环境配置

# API Gateway
API_GATEWAY_PORT=8000

# LLM Service
LLM_SERVICE_PORT=8001
OLLAMA_URL=http://localhost:11434

# Memory Service
MEMORY_SERVICE_PORT=8002
MEMORY_DIR=./memory

# Cognition Service
COGNITION_SERVICE_PORT=8003

# Vision Service
VISION_SERVICE_PORT=8004

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Multimodal Service
MULTIMODAL_SERVICE_PORT=8005

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=bayesian_agi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
